builder $P2PTrade$init$_store(builder build_0, (int, slice, slice, slice, int) v) inline {
    var (v'id, v'seller, v'buyer, v'arbitrator, v'amount) = v;
    build_0 = build_0.store_int(v'id, 257);
    build_0 = build_0.store_slice(v'seller);
    build_0 = build_0.store_slice(v'buyer);
    var build_1 = begin_cell();
    build_1 = build_1.store_slice(v'arbitrator);
    build_1 = build_1.store_int(v'amount, 257);
    build_0 = store_builder_ref(build_0, build_1);
    return build_0;
}

cell $P2PTrade$_child_get_code() impure asm """
    B{} B>boc PUSHREF
""";

(cell, cell) $P2PTrade$_init_child(int $id, slice $seller, slice $buyer, slice $arbitrator, int $amount) inline_ref {
    ;; Build init code cell

    ;; Contract Code: P2PTrade
    cell init_code = $P2PTrade$_child_get_code();


    builder b = begin_cell();
    b = b.store_int(false, 1);
    b = $P2PTrade$init$_store(b, ($id, $seller, $buyer, $arbitrator, $amount));
    return (init_code, b.end_cell());
}

