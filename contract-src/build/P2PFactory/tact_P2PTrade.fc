builder $P2PTrade$_store(builder build_0, (int, slice, slice, slice, int, int, int) v) inline {
    var (v'id, v'seller, v'buyer, v'arbitrator, v'amount, v'isPaid, v'isDisputed) = v;
    build_0 = build_0.store_uint(v'id, 32);
    build_0 = build_0.store_slice(v'seller);
    build_0 = build_0.store_slice(v'buyer);
    build_0 = build_0.store_slice(v'arbitrator);
    build_0 = build_0.store_varuint16(v'amount);
    build_0 = build_0.store_int(v'isPaid, 1);
    build_0 = build_0.store_int(v'isDisputed, 1);
    return build_0;
}

(slice, ((int, slice, slice, slice, int, int, int))) $P2PTrade$_load(slice sc_0) inline {
    var v'id = sc_0~load_uint(32);
    var v'seller = sc_0~load_msg_addr();
    var v'buyer = sc_0~load_msg_addr();
    var v'arbitrator = sc_0~load_msg_addr();
    var v'amount = sc_0~load_varuint16();
    var v'isPaid = sc_0~load_int(1);
    var v'isDisputed = sc_0~load_int(1);
    return (sc_0, (v'id, v'seller, v'buyer, v'arbitrator, v'amount, v'isPaid, v'isDisputed));
}

(slice, ((int, slice, slice, slice, int))) $P2PTrade$init$_load(slice sc_0) inline {
    var v'id = sc_0~load_int(257);
    var v'seller = sc_0~load_msg_addr();
    var v'buyer = sc_0~load_msg_addr();
    slice sc_1 = sc_0~load_ref().begin_parse();
    var v'arbitrator = sc_1~load_msg_addr();
    var v'amount = sc_1~load_int(257);
    return (sc_0, (v'id, v'seller, v'buyer, v'arbitrator, v'amount));
}

(int, slice, slice, slice, int, int, int) $P2PTrade$_contract_load() impure inline {
    slice $sc = get_data().begin_parse();
    int $loaded = $sc~load_int(1);
    if ($loaded) {
        return $sc~$P2PTrade$_load();
    }
    else {
        (int $id, slice $seller, slice $buyer, slice $arbitrator, int $amount) = $sc~$P2PTrade$init$_load();
        $sc.end_parse();
        return $P2PTrade$_contract_init($id, $seller, $buyer, $arbitrator, $amount);
    }
}

() $P2PTrade$_contract_store((int, slice, slice, slice, int, int, int) v) impure inline {
    builder b = begin_cell();
    b = b.store_int(true, 1);
    b = $P2PTrade$_store(b, v);
    set_data(b.end_cell());
}

;;
;; Contract P2PTrade functions
;;

(int, slice, slice, slice, int, int, int) $P2PTrade$_contract_init(int $id, slice $seller, slice $buyer, slice $arbitrator, int $amount) impure inline {
    var (($self'id, $self'seller, $self'buyer, $self'arbitrator, $self'amount, $self'isPaid, $self'isDisputed)) = (null(), null(), null(), null(), null(), false, false);
    $self'id = $id;
    $self'seller = $seller;
    $self'buyer = $buyer;
    $self'arbitrator = $arbitrator;
    $self'amount = $amount;
    return ($self'id, $self'seller, $self'buyer, $self'arbitrator, $self'amount, $self'isPaid, $self'isDisputed);
}

((int, slice, slice, slice, int, int, int), slice) $P2PTrade$_fun_tradeData((int, slice, slice, slice, int, int, int) $self) impure inline_ref {
    var (($self'id, $self'seller, $self'buyer, $self'arbitrator, $self'amount, $self'isPaid, $self'isDisputed)) = $self;
    var $fresh$ret_0 = $self'seller;
    return (($self'id, $self'seller, $self'buyer, $self'arbitrator, $self'amount, $self'isPaid, $self'isDisputed), $fresh$ret_0);
}

;;
;; Get methods of a Contract P2PTrade
